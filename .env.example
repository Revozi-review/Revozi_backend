# Application
APP_NAME=Revozi
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/revozi

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# LLM API (choose one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Business Profile (Google Reviews)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/platforms/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Email (optional for Phase 1)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Automation microservice
AUTOMATION_SERVICE_URL=http://localhost:5001
INTERNAL_SECRET=change-me-shared-secret
